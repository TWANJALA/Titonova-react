# Frontend (safe to expose)
VITE_REGISTRAR_API_BASE_URL=http://localhost:8787
VITE_HOSTING_API_BASE_URL=http://localhost:8787
VITE_REGISTRAR_GATEWAY_TOKEN=
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
JWT_SECRET=change-me-in-production
JWT_EXPIRES_SECONDS=604800
PRISMA_ENABLE=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/titonova?schema=public

# Gateway (server/registrarGateway.mjs)
REGISTRAR_GATEWAY_PORT=8787
REGISTRAR_GATEWAY_TOKEN=
HOST_BASE_URL=http://localhost:8787
OPENAI_API_KEY=REPLACE_WITH_REAL_OPENAI_API_KEY
OPENAI_MODEL=gpt-5-mini
STRIPE_SECRET_KEY=REPLACE_WITH_REAL_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_REAL_STRIPE_WEBHOOK_SECRET

# Provider adapter bridge URLs (implement these services separately)
NAMECHEAP_ADAPTER_URL=
GODADDY_ADAPTER_URL=
CLOUDFLARE_ADAPTER_URL=

# Optional native Namecheap mode (used when NAMECHEAP_API_* is set)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_SANDBOX=true
NAMECHEAP_DEFAULT_YEARS=1

# Required for native Namecheap purchases (shared across contact types)
NAMECHEAP_CONTACT_FIRST_NAME=
NAMECHEAP_CONTACT_LAST_NAME=
NAMECHEAP_CONTACT_ADDRESS1=
NAMECHEAP_CONTACT_CITY=
NAMECHEAP_CONTACT_STATE=
NAMECHEAP_CONTACT_POSTAL_CODE=
NAMECHEAP_CONTACT_COUNTRY=US
NAMECHEAP_CONTACT_PHONE=+1.5555555555

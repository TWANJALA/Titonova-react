generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String    @id @default(uuid()) @db.Uuid
  name                      String
  email                     String    @unique
  password_hash             String
  active_workspace_id       String?   @db.Uuid
  email_verified            Boolean   @default(false)
  email_verify_token        String?
  email_verify_expires_at   DateTime?
  password_reset_token      String?
  password_reset_expires_at DateTime?
  created_at                DateTime  @default(now())
  projects                  Project[]
  workspaces_owned          Workspace[]       @relation("WorkspaceOwner")
  workspace_memberships     WorkspaceMember[]
  subscriptions             Subscription[]
  generation_events         GenerationEvent[]

  @@map("users")
}

model Project {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  project_name String
  ai_prompt    String?
  created_at   DateTime  @default(now())
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  websites     Website[]

  @@index([user_id])
  @@map("projects")
}

model Website {
  id         String   @id @default(uuid()) @db.Uuid
  project_id String   @db.Uuid
  html       String   @db.Text
  css        String   @default("") @db.Text
  pages      Json
  domain     String?
  created_at DateTime @default(now())
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@map("websites")
}

model Workspace {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  owner_user_id String          @db.Uuid
  created_at  DateTime          @default(now())
  owner       User              @relation("WorkspaceOwner", fields: [owner_user_id], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]

  @@index([owner_user_id])
  @@map("workspaces")
}

model WorkspaceMember {
  id           String    @id @default(uuid()) @db.Uuid
  workspace_id String    @db.Uuid
  user_id      String    @db.Uuid
  role         String    @default("editor")
  created_at   DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id])
  @@index([workspace_id])
  @@index([user_id])
  @@map("workspace_members")
}

model Subscription {
  id                     String   @id @default(uuid()) @db.Uuid
  user_id                String   @db.Uuid
  plan                   String
  status                 String   @default("active")
  stripe_customer_id     String?
  stripe_subscription_id String?
  created_at             DateTime @default(now())
  user                   User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("subscriptions")
}

model GenerationEvent {
  id           String   @id @default(uuid()) @db.Uuid
  user_id      String   @db.Uuid
  project_name String?
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("generation_events")
}
